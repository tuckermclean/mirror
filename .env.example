# Copy to .env.local and fill in real values.
# Never commit .env.local to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Neon connection string (or local postgres for docker-compose)
DATABASE_URL=postgres://mirror:mirror@localhost:5432/mirror

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Upstash Redis URL or self-hosted (redis://localhost:6379 for local dev)
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Clerk — Authentication
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Client-side Clerk key (injected at Next.js build time)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# ---------------------------------------------------------------------------
# Anthropic — LLM
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-replace_me

# Hard monthly spend cap in USD (generation returns 402 when exceeded)
LLM_MONTHLY_CAP_USD=20

# ---------------------------------------------------------------------------
# Stripe — Payments
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ---------------------------------------------------------------------------
# PostHog — Analytics + Session Replay
# ---------------------------------------------------------------------------
POSTHOG_API_KEY=phc_replace_me

# Client-side PostHog key (injected at Next.js build time)
NEXT_PUBLIC_POSTHOG_KEY=phc_replace_me

# ---------------------------------------------------------------------------
# Inngest — Background Job Orchestration
# ---------------------------------------------------------------------------
INNGEST_EVENT_KEY=replace_me
INNGEST_SIGNING_KEY=replace_me

# ---------------------------------------------------------------------------
# Cookie Encryption — LinkedIn session cookie (libsodium)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ---------------------------------------------------------------------------
COOKIE_ENCRYPTION_KEY=replace_me_with_32_byte_base64_value

# ---------------------------------------------------------------------------
# Cloudflare R2 — Object Storage
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_NAME=mirror-uploads

# ---------------------------------------------------------------------------
# Embedding Provider
# ---------------------------------------------------------------------------
# Options: voyage | openai (default: voyage)
EMBEDDING_PROVIDER=voyage

# Voyage AI key (required when EMBEDDING_PROVIDER=voyage)
VOYAGE_API_KEY=replace_me

# OpenAI key (required when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-replace_me
