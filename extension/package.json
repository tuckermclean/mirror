{
  "name": "mirror-extension",
  "displayName": "Mirror — Voice Match for LinkedIn",
  "version": "0.1.0",
  "description": "Mirror Chrome extension: shows your Voice Match Score on your live LinkedIn profile and assists field-by-field edits (you confirm every change).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.43",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "happy-dom": "15.11.7",
    "typescript": "5.9.3"
  },
  "manifest": {
    "host_permissions": [
      "https://www.linkedin.com/in/*"
    ],
    "permissions": [
      "storage"
    ]
  }
}
