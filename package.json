  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^20.0.0",
    "axe-core": "^4.10.0",
    "promptfoo": "^0.108.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
