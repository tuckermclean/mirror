{
  "name": "mirror",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Personalized LinkedIn profile rewriter",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual",
    "test:a11y": "playwright test tests/a11y",
    "test:perf": "playwright test tests/perf",
    "infra:test": "vitest run tests/infra",
    "eval:prompts": "promptfoo eval --config evals/prompts/interview_system.yaml",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "setup:clerk": "bash scripts/setup-clerk.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@clerk/testing": "^2.0.27",
    "@playwright/test": "^1.51.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.10.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "promptfoo": "^0.121.0",
    "shadcn": "^4.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.3.3",
    "@tailwindcss/postcss": "^4.3.0",
    "ai": "^6.0.180",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "inngest": "^4.4.0",
    "ioredis": "^5.11.0",
    "libsodium-wrappers": "^0.8.4",
    "lucide-react": "^1.17.0",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.14",
    "postgres": "^3.4.9",
    "posthog-js": "^1.376.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "voyageai": "^0.2.1"
  }
}
